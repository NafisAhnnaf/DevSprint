{
  "dashboard": {
    "title": "IUT Microservices Dashboard",
    "description": "Complete monitoring for all services",
    "timezone": "browser",
    "panels": [
      {
        "title": "Service Health Status",
        "type": "stat",
        "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "up",
            "legendFormat": "{{service}}"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        }
      },
      {
        "title": "Active Connections",
        "type": "stat",
        "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(active_connections)",
            "legendFormat": "Total Active"
          }
        ]
      },
      {
        "title": "Request Rate (per second)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[1m])) by (service)",
            "legendFormat": "{{service}}"
          }
        ]
      },
      {
        "title": "Request Duration (95th Percentile)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
            "legendFormat": "{{service}}"
          }
        ]
      },
      {
        "title": "Error Rate by Service",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(errors_total[5m])) by (service, type)",
            "legendFormat": "{{service}} - {{type}}"
          }
        ]
      },
      {
        "title": "Orders Processed",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(orders_total[5m])) by (service, status)",
            "legendFormat": "{{service}} - {{status}}"
          }
        ]
      },
      {
        "title": "Database Query Duration",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "rate(database_query_duration_seconds_sum[5m]) / rate(database_query_duration_seconds_count[5m])",
            "legendFormat": "{{operation}} - {{table}}"
          }
        ]
      },
      {
        "title": "RabbitMQ Message Rate",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "targets": [
          {
            "expr": "sum(rate(rabbitmq_messages_total[5m])) by (queue, action)",
            "legendFormat": "{{queue}} - {{action}}"
          }
        ]
      },
      {
        "title": "Memory Usage by Service",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
        "targets": [
          {
            "expr": "process_resident_memory_bytes / (1024 * 1024)",
            "legendFormat": "{{service}}"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          }
        }
      },
      {
        "title": "CPU Usage",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[1m])",
            "legendFormat": "{{service}}"
          }
        ]
      }
    ],
    "templating": {
      "list": [
        {
          "current": {
            "selected": true,
            "text": "Prometheus",
            "value": "Prometheus"
          },
          "hide": 0,
          "label": "Data Source",
          "name": "datasource",
          "options": [],
          "query": "prometheus",
          "refresh": 1,
          "type": "datasource"
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": { "type": "grafana", "uid": "-- Grafana --" },
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    },
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" }
  },
  "overwrite": true
}
